"""Autogenerated tests ensuring benchmark coverage."""
from std.testing import (
    assert_true,
    assert_false,
    assert_equal,
    assert_raises,
    TestSuite,
)
from emberregex import compile, RegexFlags


def test_benchmarks() raises:
    var re1 = compile("needle")
    var r1 = re1.search("a" * 10000 + "needle")
    assert_true(r1.matched)
    assert_equal(r1.start, 10000)
    assert_equal(r1.end, 10006)

    var re2 = compile("[xyz]+")
    var r2 = re2.search("a" * 9990 + "xyzxyzxyz")
    assert_true(r2.matched)
    assert_equal(r2.start, 9990)

    var re3 = compile("zzzzzz")
    var r3 = re3.search("a" * 100000)
    assert_false(r3.matched)

    var re4 = compile("^hello")
    var r4 = re4.search("hello world")
    assert_true(r4.matched)
    assert_equal(r4.end, 5)

    var re5 = compile("world$")
    var r5 = re5.search("hello world")
    assert_true(r5.matched)
    assert_equal(r5.start, 6)

    var re6 = compile(r"\bworld\b")
    var r6 = re6.search("say hello world today")
    assert_true(r6.matched)
    assert_equal(r6.start, 10)

    var re7 = compile(r"\borld\b")
    var r7 = re7.search("say hello world today")
    assert_false(r7.matched)

    var re8 = compile("^\\w+", RegexFlags(RegexFlags.MULTILINE))
    var r8 = re8.findall("line 0 some text here\nline 1 some text here")
    assert_equal(len(r8), 2)
    assert_equal(r8[0], "line")
    assert_equal(r8[1], "line")

    var re10 = compile("<body>.*</body>", RegexFlags(RegexFlags.DOTALL))
    var r10 = re10.match("<body>\nline1\nline2\nline3\n</body>")
    assert_true(r10.matched)

    var re11 = compile("(?P<year>\\d{4})-(?P<month>\\d{2})-(?P<day>\\d{2})")
    var r11 = re11.match("2026-03-21")
    assert_true(r11.matched)
    assert_equal(r11.group_str("2026-03-21", 1), "2026")
    assert_equal(r11.group_str("2026-03-21", 2), "03")
    assert_equal(r11.group_str("2026-03-21", 3), "21")

    var re13 = compile("\\w+(?!@)")
    var r13 = re13.search("hello world")
    assert_true(r13.matched)

    var re14 = compile("(?<!\\d)\\w+")
    var r14 = re14.search("hello world")
    assert_true(r14.matched)

    var re15 = compile("(?=.*[a-z])(?=.*[A-Z])(?=.*\\d).{8,}")
    var r15 = re15.match("MyP4ssw0rd")
    assert_true(r15.matched)

    var re16 = compile(
        "alpha|beta|gamma|delta|epsilon|zeta|eta|theta|iota|kappa|lambda|mu|nu|xi|omicron|pi"
    )
    var r16 = re16.match("pi")
    assert_true(r16.matched)

    var re17 = compile("a?a?a?a?a?a?a?a?a?a?a?a?a?a?a?a?aaaaaaaaaaaaaaaa")
    var r17 = re17.match("aaaaaaaaaaaaaaaa")
    assert_true(r17.matched)

    var re18 = compile("^.*x$")
    var r18 = re18.match("a" * 100 + "x")
    assert_true(r18.matched)

    var re19 = compile(".*x")
    var r19 = re19.match("a" * 100)
    assert_false(r19.matched)

    var re20 = compile("(https?|ftp)://([^/\\s]+)(/[^\\s]*)?")
    var r20 = re20.match("https://www.example.com/path/to/page?q=1&r=2")
    assert_true(r20.matched)
    assert_equal(
        r20.group_str("https://www.example.com/path/to/page?q=1&r=2", 1),
        "https",
    )
    assert_equal(
        r20.group_str("https://www.example.com/path/to/page?q=1&r=2", 2),
        "www.example.com",
    )
    assert_equal(
        r20.group_str("https://www.example.com/path/to/page?q=1&r=2", 3),
        "/path/to/page?q=1&r=2",
    )

    var re21 = compile("\\(?\\d{3}\\)?[-.\\s]?\\d{3}[-.\\s]?\\d{4}")
    var r21 = re21.match("(555) 123-4567")
    assert_true(r21.matched)

    var re22 = compile("#[0-9a-fA-F]{6}")
    var r22 = re22.match("#1a2B3c")
    assert_true(r22.matched)

    var re23 = compile("(\\d+)\\.(\\d+)\\.(\\d+)(?:-(\\w+(?:\\.\\w+)*))?")
    var r23 = re23.match("12.34.56-beta.1")
    assert_true(r23.matched)
    assert_equal(r23.group_str("12.34.56-beta.1", 1), "12")
    assert_equal(r23.group_str("12.34.56-beta.1", 2), "34")
    assert_equal(r23.group_str("12.34.56-beta.1", 3), "56")
    assert_equal(r23.group_str("12.34.56-beta.1", 4), "beta.1")

    var re24 = compile("(\\w+)=(\\S+)")
    var r24 = re24.findall("host=localhost port=5432")
    assert_equal(len(r24), 2)
    assert_equal(r24[0], "host")
    assert_equal(r24[1], "port")

    var re25 = compile("<(\\w+)[^>]*>")
    var r25 = re25.findall(
        "<html><head><title>Test</title></head><body><div"
        ' class="x"><p>Hello</p><a href="#">Link</a></div></body></html>'
    )
    assert_equal(len(r25), 7)
    assert_equal(r25[0], "html")

    var re26 = compile("\\s+")
    var r26 = re26.replace("hello   world\t\tfoo  bar\n\nbaz   qux", " ")
    assert_equal(r26, "hello world foo bar baz qux")

    var re27 = compile("([a-z]+)\\d+\\1")
    var r27 = re27.match("abc123abc")
    assert_true(r27.matched)

    var re28 = compile("(?i)hello world")
    var r28 = re28.match("HeLLo WoRLd")
    assert_true(r28.matched)


def main() raises:
    TestSuite.discover_tests[__functions_in_module()]().run()
